@page "/"
@page "/{selectedLeague}"
@page "/{selectedLeague}/{tabName}"

@using Microsoft.AspNetCore.Components.Sections
@using PoeLeagueTracker.Client.Components
@using PoeLeagueTracker.Client.Components.Icons
@using PoeLeagueTracker.Shared.DTOs
@using System.Web

@inject HttpClient PoeTrackerApi;
@inject NavigationManager Navigation;
@inject IConfiguration Config;

<div class="page-wrapper">
    <header class="poe-header">

        <div class="header-content">
            <div class="title-section">
                <a class="logo-circle" href="/@HttpUtility.UrlEncode(Config["ActiveLeague"])">
                    <TrackerIcon></TrackerIcon>
                </a>
                <div>
                    <h1 class="page-title">Fizz Leagues</h1>
                    <p class="page-subtitle">PoE Private League Tracker</p>
                </div>
            </div>

            <div class="league-selector-container">
                <div class="poe-select-wrapper">
                    <select class="poe-dropdown" value="@selectedLeague" @onchange="HandleSelectorChanged">
                        <optgroup label="Active League">
                            <option value="@Config["ActiveLeague"]">@Config["ActiveLeague"]</option>
                        </optgroup>

                        <optgroup label="Past leagues">
                            @foreach (var league in leagues!.Where(league => league != Config["ActiveLeague"]))
                            {
                                <option value="@league">@league</option>
                            }
                        </optgroup>
                    </select>

                <span class="poe-select-arrow"></span>
                </div>
            </div>

        </div>

        <nav class="poe-tabs-container">
            <a class="poe-tab @(tabName == "ladder" || string.IsNullOrEmpty(tabName) ? "active" : "")" href="/@HttpUtility.UrlEncode(selectedLeague)/ladder">
                <LadderIcon fill=@(tabName == "ladder" || string.IsNullOrEmpty(tabName) ? "var(--text-bright)" : "var(--text-muted)")></LadderIcon> Ladder
            </a>

            <a class="poe-tab @(tabName == "stats" ? "active" : "")" href="/@HttpUtility.UrlEncode(selectedLeague)/stats">
                <LeaderboardIcon fill=@(tabName == "stats" ? "var(--text-bright)" : "var(--text-muted)")></LeaderboardIcon> Leaderboards
            </a>
        </nav>
    </header>

    <main class="main-content">
        @if (tabName == "stats")
        {
            if (characters == null)
            {
                <h1>Loading characters...</h1>                
            }
            else
            {
                <div class="stats-grid">
                <XpStatCard characters="characters"></XpStatCard>
                <CharCountStatCard characters="characters"></CharCountStatCard>
                @if (selectedLeague == Config["ActiveLeague"])
                    {
                        <ChallengesCard characters="characters"></ChallengesCard>
                    }
                <DeathStatCard characters="characters"></DeathStatCard>
                </div>
            }
        }
        else
        {
            if (characters == null)
            {
                <h1>Loading characters..</h1>
            }
            else
            {
                <LadderCard characters="characters"></LadderCard>
            }
        }
    </main>
</div>

@code {
    public List<string>? leagues { get; set; } = [];

    [Parameter]
    public string selectedLeague { get; set; } = string.Empty;

    public LeagueDto? league { get; set; }
    public List<CharacterDto>? characters { get; set; }

    [Parameter]
    public string tabName { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        selectedLeague = Config["ActiveLeague"]!;

        await FetchLeagueNames();

        await FetchLeague();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(selectedLeague))
        {
            selectedLeague = HttpUtility.UrlDecode(selectedLeague);
            await FetchLeague();
        }
    }

    private async Task FetchLeagueNames()
    {
        var response = await PoeTrackerApi.GetAsync("allLeagueNames");

        leagues = await response.Content.ReadFromJsonAsync<List<string>>();

        if (leagues?.Any() == true && string.IsNullOrEmpty(selectedLeague)) selectedLeague = leagues.First();
    }

    private async Task FetchLeague()
    {
        var response = await PoeTrackerApi.GetAsync($"/league/{selectedLeague}");

        league = await response.Content.ReadFromJsonAsync<LeagueDto>();
        characters = league!.Characters.ToList();
    }

    private async Task HandleSelectorChanged(ChangeEventArgs args)
    {
        selectedLeague = args.Value?.ToString();

        if (!string.IsNullOrEmpty(selectedLeague))
        {
            string targetTab = string.IsNullOrEmpty(tabName) ? "ladder" : tabName;
            Navigation.NavigateTo($"/{HttpUtility.UrlEncode(selectedLeague)}/{targetTab}");
        }
    }
}
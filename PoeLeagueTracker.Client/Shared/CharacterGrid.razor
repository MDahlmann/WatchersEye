@using System.Linq
@using PoeLeagueTracker.Shared.DTOs
@using Radzen
@using Radzen.Blazor

@* @inject DialogService DialogService *@

<RadzenDataGrid @ref="charactersGrid" AllowFiltering="false" FilterPopupRenderMode="PopupRenderMode.OnDemand" AllowPaging="true" PageSize="20" AllowSorting="false"
                Data="@characters" TItem="CharacterDto" CellRender="@CellRender">
    <Columns>
        <RadzenDataGridColumn Width="50px" Title="#" TextAlign="TextAlign.Center">
            <Template Context="character">
                @(character.Rank)
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="Character.Name" Title="Character"> 
            <Template Context="Character">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-0">@Character.Name</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-mb-0">@Character.AccountName</RadzenText>
                    </RadzenStack>
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="@nameof(CharacterDto.Level)" Title="Level" Width="60px"/>
        <RadzenDataGridColumn Property="@nameof(CharacterDto.ClassName)" Title="Class" />
        <RadzenDataGridColumn Property="@nameof(CharacterDto.CompletedChallenges)" Title="Challenges" />
        <RadzenDataGridColumn Property="@nameof(CharacterDto.Experience)" Title="Experience" />
        <RadzenDataGridColumn Property="@nameof(CharacterDto.Depth)" Title="Delve" />
    </Columns>
</RadzenDataGrid>

@code {
    RadzenDataGrid<CharacterDto>? charactersGrid;

    [Parameter, EditorRequired]
    public required List<CharacterDto> characters { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    void CellRender(RowRenderEventArgs<CharacterDto> args)
    {
        if (args.Data!.Dead == true)
        {
            args.Attributes.Add("style", $"background-color: salmon;");
        }
        
        if (args.Data!.Retired == true)
        {
            args.Attributes.Add("style", $"background-color: lightgrey;");
        }
    }
}

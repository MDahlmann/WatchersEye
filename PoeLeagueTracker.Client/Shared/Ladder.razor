    <div class="corner bottom-right"></div>

    <div class="table-scroll">
        <table class="ladder-table">
            <thead>
                <tr>
                    <th class="col-rank">Rank</th>
                    <th>Character</th>
                    <th>Account</th>
                    <th>Class</th>
                    <th class="col-number">Level</th>
                </tr>
            </thead>
            <tbody>
                <tr class="ladder-row">
                    <td class="col-rank"><span class="rank-first arpg-font">1</span></td>
